		"tauri": "tauri",
		"tauri:dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
		"tauri:build": "NO_STRIP=1 tauri build"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
