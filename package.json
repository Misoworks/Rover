		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/cli": "^2.11.2",
		"@types/node": "^25.9.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.5.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0"
	}
